<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#F5F6FA">

    <!-- Titre -->

    <!-- Conteneur horizontal pour les deux boutons -->

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Choisissez votre type de compte"
        android:textAlignment="center"
        android:textColor="#2C3E50"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="800dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- Bouton Utilisateur normal -->
        <Button
            android:id="@+id/btnNormalUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_rounded_teal"
            android:drawableTop="@drawable/icons8_user_white_100"
            android:drawablePadding="12dp"
            android:gravity="center"
            android:minHeight="160dp"
            android:padding="16dp"
            android:text="Utilisateur normal"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Bouton Prestataire -->
        <Button
            android:id="@+id/btnProvider"
            android:layout_width="0dp"
            android:layout_height="191dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_rounded_teal"
            android:drawableTop="@drawable/icons8_tools_100"
            android:drawablePadding="12dp"
            android:gravity="center"
            android:minHeight="160dp"
            android:padding="16dp"
            android:text="Prestataire"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
            

    </LinearLayout>

    <!-- Lien de connexion en bas -->
    <TextView
        android:id="@+id/linkSignIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        android:text="@string/link_sign_in"
        android:textAlignment="center"
        android:textColor="#5E6AD2"
        android:textSize="14sp" />

</LinearLayout>
