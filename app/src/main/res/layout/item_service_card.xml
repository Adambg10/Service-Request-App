<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E0E6F6"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Left side: Avatar with profession label underneath -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="16dp"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/imageService"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@string/logo_description"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/ic_service_placeholder"
                tools:ignore="MissingPrefix" />

            <!-- Profession label with icon -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imageProfessionIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Profession icon"

                    app:tint="#6B7A99"
                    tools:ignore="MissingPrefix" />

                <TextView
                    android:id="@+id/textProfession"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#6B7A99"
                    android:textSize="13sp"
                    tools:text="Électricien" />
            </LinearLayout>
        </LinearLayout>

        <!-- Middle: Provider info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Provider name (now the main title) -->
            <TextView
                android:id="@+id/textServiceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_color"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Ahmed Salah" />

            <!-- Description -->
            <TextView
                android:id="@+id/textServiceDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#6B7A99"
                android:textSize="14sp"
                tools:text="Interventions rapides, dépannage 24/7" />

            <!-- Rating row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/logo_description"
                    app:srcCompat="@drawable/outline_star_24"
                    tools:ignore="MissingPrefix" />

                <TextView
                    android:id="@+id/textServiceRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#FFA726"
                    android:textSize="14sp"
                    tools:text="4.8" />

                <TextView
                    android:id="@+id/textServiceReviews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#9AA4C1"
                    android:textSize="14sp"
                    tools:text="(128 avis)" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right side: Action buttons stacked vertically -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonBook"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demander"
                android:textAllCaps="false"
                android:textColor="@color/light_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonViewProfile"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voir Profile"
                android:textAllCaps="false"
                android:textColor="@color/light_blue" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
