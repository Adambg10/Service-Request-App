<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer circle - lightest green -->
    <item
        android:width="48dp"
        android:height="48dp">
        <shape android:shape="oval">
            <solid android:color="#C8E6C9" />
        </shape>
    </item>
    <!-- Middle circle - medium green -->
    <item
        android:width="36dp"
        android:height="36dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#4CAF50" />
        </shape>
    </item>
    <!-- Inner circle - dark green -->
    <item
        android:width="26dp"
        android:height="26dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#2E7D32" />
        </shape>
    </item>
    <!-- Plumbing icon -->
    <item
        android:width="18dp"
        android:height="18dp"
        android:gravity="center"
        android:drawable="@drawable/outline_plumbing_24" />
</layer-list>
