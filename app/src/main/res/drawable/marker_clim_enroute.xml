<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer circle - lightest yellow -->
    <item
        android:width="48dp"
        android:height="48dp">
        <shape android:shape="oval">
            <solid android:color="#FFF9C4" />
        </shape>
    </item>
    <!-- Middle circle - medium yellow/amber -->
    <item
        android:width="36dp"
        android:height="36dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#FFC107" />
        </shape>
    </item>
    <!-- Inner circle - dark amber -->
    <item
        android:width="26dp"
        android:height="26dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#FF8F00" />
        </shape>
    </item>
    <!-- AC unit icon -->
    <item
        android:width="18dp"
        android:height="18dp"
        android:gravity="center"
        android:drawable="@drawable/baseline_ac_unit_24" />
</layer-list>
